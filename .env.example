# ─────────────────────────────────────────────────────────────────────────────
# Database — Supabase Postgres
# ─────────────────────────────────────────────────────────────────────────────
# Supabase gives you TWO connection strings. Use both:
#
#   DATABASE_URL  → Transaction-mode pooler (PgBouncer), port 6543, used by
#                  the Next.js serverless runtime. Prisma's "URL" with many
#                  short-lived clients must hit this one to avoid exhausting
#                  connection slots.
#
#   DIRECT_URL    → Session-mode direct connection, port 5432. Prisma uses
#                  this for `migrate dev`, `migrate deploy`, and `db push` —
#                  anything that needs a long-lived single connection.
#
# Get them: Supabase Dashboard → Project → Settings → Database →
#   "Connection string" → "URI" tab → Transaction (pooled)   → DATABASE_URL
#                        "URI" tab → Session    (direct)    → DIRECT_URL
#
# Always append `?sslmode=require` if Supabase didn't already.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Production: https://subauditor-mu.vercel.app
# Generate a real secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE-WITH-32-BYTE-RANDOM-VALUE"

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth (optional but recommended)
# ─────────────────────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://subauditor-mu.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# Plaid (optional — site renders fine without these; feature just disabled)
# ─────────────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (optional)
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_ANNUAL=""
