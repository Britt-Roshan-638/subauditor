# === Database (PostgreSQL) ===
# For local dev: use Neon or Supabase pooled connection
# For migrations: use direct connection (port 5432)
DATABASE_URL="postgresql://user:pass@host:6543/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# === NextAuth ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# === Google OAuth (optional) ===
# Leave empty to disable Google sign-in
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Razorpay ===
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_PLAN_ID_MONTHLY="plan_xxxxxxxxxxxx"
RAZORPAY_PLAN_ID_ANNUAL="plan_annual_xxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# === Plaid (optional — enables bank sync) ===
# Get from https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# === Admin ===
# Email of the admin user (required for /api/admin/seed)
ADMIN_EMAIL="admin@example.com"
